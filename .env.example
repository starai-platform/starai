# StarAI production environment template
#
# Usage:
#   cp .env.example .env.production
#   edit .env.production
#   bash scripts/deploy-prod.sh
#
# This file is for production Docker Compose deployment.
# For local development, use .env.local instead.

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
# The default password is allowed for quick deployment. Change it before public
# production use if you need stronger isolation.
POSTGRES_USER=starai
POSTGRES_PASSWORD=change_this_to_a_strong_password
POSTGRES_DB=starai
DATABASE_URL=postgres://starai:change_this_to_a_strong_password@postgres:5432/starai?sslmode=disable

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0
REDIS_MAXMEMORY=1gb

# -----------------------------------------------------------------------------
# JWT
# -----------------------------------------------------------------------------
# Defaults are allowed for quick deployment. Change both secrets before public
# production use because JWT secrets protect login tokens.
JWT_SECRET=replace_with_a_long_random_secret
ADMIN_JWT_SECRET=replace_with_another_long_random_secret
JWT_EXPIRE_HOURS=72

# -----------------------------------------------------------------------------
# API Server
# -----------------------------------------------------------------------------
APP_ENV=production
TRUSTED_PROXIES=127.0.0.1,::1,172.16.0.0/12
API_PORT=8080
BASE_URL=https://yourdomain.com

# Local upload fallback. Production should prefer R2/S3.
LOCAL_STORAGE_DIR=
LOCAL_STORAGE_PUBLIC_URL=https://yourdomain.com/uploads-local

# -----------------------------------------------------------------------------
# Frontend
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=https://yourdomain.com

# Admin static assets for single-domain deployment.
# Must match the Nginx /admin-assets/_next/ rule.
ADMIN_ASSET_PREFIX=/admin-assets

# -----------------------------------------------------------------------------
# R2 / S3 compatible storage
# -----------------------------------------------------------------------------
MINIO_ENDPOINT=<accountid>.r2.cloudflarestorage.com
MINIO_ACCESS_KEY=your_r2_access_key
MINIO_SECRET_KEY=your_r2_secret_key
MINIO_BUCKET=starai-works
MINIO_PUBLIC_URL=https://cdn.yourdomain.com
MINIO_USE_SSL=true

# -----------------------------------------------------------------------------
# Model gateway
# -----------------------------------------------------------------------------
NEW_API_BASE_URL=https://your-model-gateway.example.com
NEW_API_TOKEN=your_model_gateway_token
NEW_API_TIMEOUT_SECONDS=300
NEW_API_STREAM_TIMEOUT_SECONDS=600
