# StarAI environment template
#
# Local development:
#   cp .env.example .env
#   keep the localhost defaults unless you know what you are changing.
#
# Production / Baota / Docker Compose:
#   cp .env.example .env.production
#   change all passwords, secrets, domains and storage credentials before deploy.

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
# Required by infra/docker/docker-compose.prod.yml.
# POSTGRES_PASSWORD must not be empty in production.
POSTGRES_USER=starai
POSTGRES_PASSWORD=starai
POSTGRES_DB=starai

# Local development usually uses localhost.
# Production Docker Compose must use host "postgres" and the same password above:
#   postgres://starai:<POSTGRES_PASSWORD>@postgres:5432/starai?sslmode=disable
DATABASE_URL=postgres://starai:starai@localhost:5432/starai?sslmode=disable

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
# Local development: redis://localhost:6379/0
# Production Docker Compose: redis://redis:6379/0
REDIS_URL=redis://localhost:6379/0
REDIS_MAXMEMORY=1gb

# -----------------------------------------------------------------------------
# Storage
# -----------------------------------------------------------------------------
# Local development can use the bundled MinIO or local uploads.
# Production is recommended to use R2/S3 compatible object storage.
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=starai
MINIO_SECRET_KEY=starai123
MINIO_BUCKET=starai-works
MINIO_PUBLIC_URL=http://localhost:9000
MINIO_USE_SSL=false

# Local upload fallback.
# Production local storage requires LOCAL_STORAGE_PUBLIC_URL or BASE_URL.
LOCAL_STORAGE_DIR=
LOCAL_STORAGE_PUBLIC_URL=http://localhost:8080/uploads-local

# -----------------------------------------------------------------------------
# JWT
# -----------------------------------------------------------------------------
# Change both secrets in production. Use long random strings.
JWT_SECRET=change-me-in-production-starai-jwt-secret
ADMIN_JWT_SECRET=change-me-admin-jwt-secret
JWT_EXPIRE_HOURS=72

# -----------------------------------------------------------------------------
# API Server
# -----------------------------------------------------------------------------
# Local development: development
# Production: production
APP_ENV=development
API_PORT=8080

# Production example:
#   BASE_URL=https://yourdomain.com
BASE_URL=

# -----------------------------------------------------------------------------
# Frontend
# -----------------------------------------------------------------------------
# Local development: http://localhost:8080
# Single-domain production example:
#   NEXT_PUBLIC_API_URL=https://yourdomain.com
NEXT_PUBLIC_API_URL=http://localhost:8080

# Admin static asset prefix for single-domain deployment.
# Must match the Nginx /admin-assets/_next/ rule.
ADMIN_ASSET_PREFIX=/admin-assets

# -----------------------------------------------------------------------------
# Model gateway
# -----------------------------------------------------------------------------
# Mock gateway by default for local development.
NEW_API_BASE_URL=http://localhost:3002
NEW_API_TOKEN=change-me-dev-model-gateway-token
NEW_API_TIMEOUT_SECONDS=300
NEW_API_STREAM_TIMEOUT_SECONDS=600
