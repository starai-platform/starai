# StarAI local development environment template
#
# Usage:
#   cp .env.local .env
#   powershell -NoProfile -ExecutionPolicy Bypass -File .\scripts\dev.ps1
#
# This file is for local one-click development. Do not use it for production.

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_USER=starai
POSTGRES_PASSWORD=starai
POSTGRES_DB=starai
DATABASE_URL=postgres://starai:starai@localhost:5432/starai?sslmode=disable

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
REDIS_MAXMEMORY=1gb

# -----------------------------------------------------------------------------
# Storage
# -----------------------------------------------------------------------------
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=starai
MINIO_SECRET_KEY=starai123
MINIO_BUCKET=starai-works
MINIO_PUBLIC_URL=http://localhost:9000
MINIO_USE_SSL=false

LOCAL_STORAGE_DIR=
LOCAL_STORAGE_PUBLIC_URL=http://localhost:8080/uploads-local

# -----------------------------------------------------------------------------
# JWT
# -----------------------------------------------------------------------------
JWT_SECRET=dev-jwt-secret-starai
ADMIN_JWT_SECRET=dev-admin-jwt-secret
JWT_EXPIRE_HOURS=72

# -----------------------------------------------------------------------------
# API Server
# -----------------------------------------------------------------------------
APP_ENV=development
API_PORT=8080
BASE_URL=

# -----------------------------------------------------------------------------
# Frontend
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8080
ADMIN_ASSET_PREFIX=

# -----------------------------------------------------------------------------
# Local mock model gateway
# -----------------------------------------------------------------------------
NEW_API_BASE_URL=http://localhost:3002
NEW_API_TOKEN=change-me-dev-model-gateway-token
NEW_API_TIMEOUT_SECONDS=300
NEW_API_STREAM_TIMEOUT_SECONDS=600
