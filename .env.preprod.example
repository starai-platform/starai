# Isolated local pre-production environment. Copy to .env.preprod.
COMPOSE_PROJECT_NAME=starai-preprod
STARAI_ENV_FILE=../../.env.preprod
APP_ENV=staging

POSTGRES_USER=starai_preprod
POSTGRES_PASSWORD=starai_preprod_only
POSTGRES_DB=starai_preprod
DATABASE_URL=postgres://starai_preprod:starai_preprod_only@postgres:5432/starai_preprod?sslmode=disable
REDIS_URL=redis://redis:6379/0
REDIS_MAXMEMORY=256mb

JWT_SECRET=preprod-user-session-secret-not-for-production
ADMIN_JWT_SECRET=preprod-admin-session-secret-not-for-production
API_PORT=8080
BASE_URL=http://localhost:18080
TRUSTED_PROXIES=127.0.0.1,::1,172.16.0.0/12

API_BIND_PORT=18080
WEB_BIND_PORT=13000
ADMIN_BIND_PORT=13001
NEXT_PUBLIC_API_URL=http://localhost:18080
ADMIN_ASSET_PREFIX=/admin-assets
UPLOADS_HOST_DIR=../../data/preprod-uploads
LOCAL_STORAGE_DIR=/app/data/uploads
LOCAL_STORAGE_PUBLIC_URL=http://localhost:18080/uploads-local

MINIO_ENDPOINT=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=starai-preprod
MINIO_PUBLIC_URL=
MINIO_USE_SSL=false

NEW_API_BASE_URL=http://mock-new-api:3002
NEW_API_TOKEN=preprod-model-gateway-token
NEW_API_TIMEOUT_SECONDS=60
NEW_API_STREAM_TIMEOUT_SECONDS=120

DOCKER_LOG_MAX_SIZE=10m
DOCKER_LOG_MAX_FILES=2
